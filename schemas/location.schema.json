{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LocationDataset",
  "type": "object",
  "required": ["metadata", "items"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["dataset", "version", "generatedAt", "language", "region", "verified", "source"],
      "properties": {
        "dataset": { "type": "string", "const": "locations" },
        "version": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "language": { "type": "string" },
        "region": { "type": "string" },
        "verified": { "type": "boolean" },
        "source": { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "slug", "title", "description", "status", "tags",
          "relationships", "verified", "source", "sourceUrl",
          "createdAt", "updatedAt", "verifiedAt", "version",
          "type"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^location_[a-z0-9_]+$" },
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["confirmed", "official", "community", "coming_soon", "deprecated"]
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "relationships": {
            "type": "object",
            "properties": {
              "characters": { "type": "array", "items": { "type": "string" } },
              "vehicles": { "type": "array", "items": { "type": "string" } },
              "trailers": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "verified": { "type": "boolean" },
          "source": { "type": "string" },
          "sourceUrl": { "type": "string", "format": "uri" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" },
          "verifiedAt": { "type": "string" },
          "version": { "type": "string" },
          "type": { "type": "string", "enum": ["state", "city", "county", "district", "landmark", "neighborhood", "unknown"] },
          "coordinates": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
